# ══════════════════════════════════════════════════════════════════════════════
# Small Smart Tools — Environment Variables
# Copy this file to .env and fill in your values.
# ══════════════════════════════════════════════════════════════════════════════

# === Required ===
# Flask session secret (auto-generated on Render via render.yaml)
# SECRET_KEY=your-secret-key

# Anthropic API key for Claude AI (Options Monitor chat)
ANTHROPIC_API_KEY=sk-ant-xxxxx

# === Brevo — Transactional Email (magic-link login) ===
BREVO_API_KEY=xkeysib-xxxx
BREVO_SENDER_EMAIL=your_verified_sender@example.com
BREVO_SENDER_NAME=Small Smart Tools

# === Optional: Database ===
# If not set, uses local SQLite files (fine for development)
# DATABASE_URL=postgresql://user:pass@localhost:5432/optionsai

# === Optional: Telegram Notifications ===
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
# TELEGRAM_CHAT_ID=123456789

# === Optional: Email Notifications (SMTP, not needed if using Brevo) ===
# EMAIL_ADDRESS=your@gmail.com
# EMAIL_PASSWORD=your_app_password
# EMAIL_SMTP_SERVER=smtp.gmail.com
# EMAIL_SMTP_PORT=587
# EMAIL_RECIPIENTS=recipient@email.com
